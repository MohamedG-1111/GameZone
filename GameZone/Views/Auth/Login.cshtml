@model GameZone.ViewModels.User.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="d-flex justify-content-center align-items-center vh-100">

    <div class="card p-5"
         style="width: 450px; background-color: #220d52; border-radius: 8px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">

        <h3 class="fw-bold mb-4"
            style="color: #00ffcc; border-bottom: 1px solid #4a1d96; padding-bottom: 15px;">
            Sign in
        </h3>

        <form asp-controller="Auth" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3 text-start">
                <label asp-for="Email" class="form-label fw-bold" style="color: #00ffcc;"></label>
                <input asp-for="Email"
                       class="form-control border-0 text-white"
                       style="background-color: #311b92; border-radius: 5px; height: 45px;" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3 text-start">
                <label asp-for="Password" class="form-label fw-bold" style="color: #00ffcc;"></label>
                <input asp-for="Password" type="password"
                       class="form-control border-0 text-white"
                       style="background-color: #311b92; border-radius: 5px; height: 45px;" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-check mb-4 text-start">
                <input asp-for="RememberMe" class="form-check-input" style="background-color: #311b92; border: none;" />
                <label asp-for="RememberMe" class="form-check-label text-white">Remember Me</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn fw-bold px-4 text-white"
                        style="background-color: #7b4cf3; border-radius: 5px; border: none;">
                    Login
                </button>
                
              
            </div>

        </form>

    </div>

</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/filesize-validator.js"></script>
    <script src="~/js/register-form.js"></script>
}