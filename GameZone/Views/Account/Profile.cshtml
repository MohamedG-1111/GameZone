@using GameZone.Settings
@model GameZone.ViewModels.User.AccountViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - GameZone</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="~/css/profile.css" rel="stylesheet" />
</head>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-lg rounded-3" role="alert" id="tempAlert">
        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
    
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-lg rounded-3" role="alert" id="tempAlert">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<body class="d-flex align-items-center min-vh-100 py-4">

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-md-11">

                <div class="card profile-card shadow-lg border-0">
                    <div class="card-body p-4 p-md-5">

                        <div class="row g-4">

                            <!-- LEFT SIDE -->
                            <div class="col-md-4 text-center border-end-md">

                                <!-- IMAGE FORM -->
                       <partial name="_AccountImagePartial" />


                                <!-- NAME -->
                                <h4 class="fw-bold mt-3 mb-1">@Model.FullName</h4>

                             

                                <!-- EDIT BUTTON -->
                                <a asp-action="EditProfile">
                                    <button class="btn btn-primary-custom w-100 mt-3">
                                        <i class="fas fa-pen me-2"></i>Update Profile
                                    </button>
                                </a>

                                <!-- STATUS -->
                                <div class="mt-3">
                                    <span class="badge bg-light text-dark px-3 py-2 rounded-pill">
                                        <i class="fas fa-check-circle text-success me-1"></i> Active
                                    </span>
                                </div>

                            </div>

                            <!-- RIGHT SIDE -->
                            <div class="col-md-8">

                                <!-- VIEW MODE -->
                                <div id="viewMode">

                                    <div class="d-flex align-items-center mb-3">
                                        <i class="fas fa-id-card fa-2x text-primary me-2"></i>
                                        <h5 class="section-title mb-0">Account Details</h5>
                                    </div>

                                    <div class="list-group list-group-flush mb-4 shadow-sm rounded-3 overflow-hidden">

                                        <div class="list-group-item d-flex align-items-center">
                                            <div class="info-icon"><i class="fas fa-envelope"></i></div>
                                            <div class="ms-3">
                                                <small class="text-muted d-block">Email Address</small>
                                                <strong>@Model.Email</strong>
                                            </div>
                                        </div>

                                        <div class="list-group-item d-flex align-items-center">
                                            <div class="info-icon"><i class="fas fa-phone-alt"></i></div>
                                            <div class="ms-3">
                                                <small class="text-muted d-block">Phone Number</small>
                                                <strong>@Model.PhoneNumber</strong>
                                            </div>
                                        </div>

                                        <div class="list-group-item d-flex align-items-center">
                                            <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                                            <div class="ms-3">
                                                <small class="text-muted d-block">Address</small>
                                                <strong>@Model.Address</strong>
                                            </div>
                                        </div>

                                    </div>

                                    <div class="alert alert-light border mt-3 rounded-3">
                                        <i class="fas fa-shield-alt text-primary me-2"></i>
                                        Your data is secure with us.
                                    </div>

                                </div>
                            </div>

                        </div>

                    </div>
                </div>

                <div class="text-center text-white-50 mt-4 small">
                    <i class="fas fa-gamepad me-1"></i> GameZone - Manage your profile
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>