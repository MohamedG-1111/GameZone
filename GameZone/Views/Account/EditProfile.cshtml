@using GameZone.Settings
@model GameZone.ViewModels.User.EditAccountViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container mt-5">

    <div class="card shadow-lg border-0 main-card">
        <div class="card-body p-4">

            <h3 class="text-info mb-4">Edit Profile</h3>
            <hr class="line" />

            <form asp-action="EditProfile" method="post">

                <div class="row">

                    <!-- Full Name -->
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label text-light"></label>
                        <input asp-for="FullName" class="form-control custom-input" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <!-- Phone -->
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label text-light"></label>
                        <input asp-for="PhoneNumber" class="form-control custom-input" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <!-- Address -->
                    <div class="mb-3">
                        <label asp-for="Address" class="form-label text-light"></label>
                        <input asp-for="Address" class="form-control custom-input" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 mt-3">

                        <button type="submit" class="btn btn-info w-100">
                            Save Changes
                        </button>

                        <a asp-action="Profile" class="btn btn-secondary w-100">
                            Cancel
                        </a>

                    </div>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}