@using GameZone.Settings
@using System.Security.Claims

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Game Zone - @ViewData["Title"]</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom CSS -->
    <link href="~/css/bootstrap.min.css" rel="stylesheet" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-light">

    <!-- Navbar -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-black shadow-lg py-3">
            <div class="container">

                <!-- Logo -->
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-controller me-2"></i>Game Zone
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">

                    <!-- Left Menu -->
                    <ul class="navbar-nav me-auto">

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Games" asp-action="Index">
                                    Manage Games
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="AddAdmin">
                                    New Admin
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>
                    </ul>

                    <!-- Right Menu -->
                    <ul class="navbar-nav align-items-center">

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
							@await Component.InvokeAsync("UserNavMenu")
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-light btn-sm px-3" asp-controller="Auth" asp-action="Register">
                                    Register
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-3" asp-controller="Auth" asp-action="Login">
                                    Login
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Body -->
    <div class="container mt-5">
        <main>
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="border-top mt-5 py-4 text-center text-muted bg-light">
        <p class="mb-0">&copy; 2026 - GameZone. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>